generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// Enums
// ------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
  COMPANY
  RESELLER
}

enum ImeiStatus {
  IN_STOCK
  SOLD
  RETURNED
  RMA
  DEFECTIVE
  LOST
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

enum ReturnType {
  RETURN
  REFUND
  REPLACEMENT
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  OTHER
}

enum PaymentDirection {
  INBOUND
  OUTBOUND
}

enum NotificationType {
  INFO
  WARNING
  ALERT
}

enum InventoryTxnType {
  PURCHASE_IN
  SALE_OUT
  RETURN_IN
  ADJUSTMENT
  TRANSFER
}

enum SimStatus {
  AVAILABLE
  ASSIGNED
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SimCarrier {
  JIO
  AIRTEL
  VI
  BSNL
  OTHER
}

enum SimBillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum InstallationStatus {
  SCHEDULED
  COMPLETED
  REMOVED
  CANCELLED
}

enum RmaStatus {
  REQUESTED
  SHIPPED_TO_SUPPLIER
  RECEIVED_BY_SUPPLIER
  REPLACED
  REPAIRED
  REJECTED
}

enum GstType {
  INTRA_STATE
  INTER_STATE
}

enum CustomerSource {
  GOOGLE
  INDIAMART
  JUSTDIAL
  WEBSITE
  REFERRAL
  OTHER
}

// ------------------------------------------------------------------
// Users & Access Control
// ------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales          Sale[]
  purchases      Purchase[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  filesUploaded  File[]
  installations  InstallationRecord[]
  simRenewals    SimRenewal[]

  @@index([role])
}

// ------------------------------------------------------------------
// Branches
// ------------------------------------------------------------------

model Branch {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  inventory     Inventory[]
  imeiRecords   ImeiRecord[]
  inventoryTxns InventoryTransaction[]
  sales         Sale[]
  purchases     Purchase[]
  sims          Sim[]
  vehicles      Vehicle[]
  installations InstallationRecord[]
  rmas          Rma[]
}

// ------------------------------------------------------------------
// Customers & Suppliers
// ------------------------------------------------------------------

model Customer {
  id           String          @id @default(uuid())
  name         String
  email        String?         @unique
  phone        String          @unique
  username     String?         @unique
  city         String?
  address      String?
  company      String?
  gstNumber    String?
  source       CustomerSource?
  notes        String?
  passwordHash String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sales           Sale[]
  returns         Return[]
  warrantyClaims  WarrantyClaim[]
  payments        Payment[]
  sims            Sim[]
  vehicles        Vehicle[]

  @@index([phone])
  @@index([email])
}

model Supplier {
  id                String   @id @default(uuid())
  name              String
  email             String?
  phone             String   @unique
  contactPerson     String?
  alternatePhone    String?
  address           String?
  addressLine2      String?
  city              String?
  state             String?
  pincode           String?
  country           String?
  gstNumber         String?
  panNumber         String?
  bankAccountNumber String?
  bankIfsc          String?
  bankAccountHolder String?
  categorySupplied  String?
  creditLimit       Decimal? @db.Decimal(12, 2)
  website           String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  purchases   Purchase[]
  products    Product[]
  rmas        Rma[]
  imeiRecords ImeiRecord[]
}

// ------------------------------------------------------------------
// Product Catalog & Inventory
// ------------------------------------------------------------------

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  parentId String?
  parent   Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  products Product[]
}

model Product {
  id             String   @id @default(uuid())
  sku            String   @unique
  name           String
  description    String?
  brand          String?
  model          String?
  hasImei        Boolean  @default(false)
  hsnCode        String?
  unitPrice      Decimal  @db.Decimal(12, 2)
  costPrice      Decimal  @db.Decimal(12, 2)
  taxPercent     Decimal  @default(0) @db.Decimal(5, 2)
  reorderLevel   Int      @default(0)
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  inventory        Inventory[]
  imeiRecords      ImeiRecord[]
  saleItems        SaleItem[]
  purchaseItems    PurchaseItem[]
  inventoryTxns    InventoryTransaction[]

  @@index([name])
}

// Per-branch stock for non-IMEI, quantity-based products
model Inventory {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id])
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([branchId])
}

model InventoryTransaction {
  id          String           @id @default(uuid())
  productId   String
  product     Product          @relation(fields: [productId], references: [id])
  type        InventoryTxnType
  quantity    Int
  reference   String?
  branchId    String
  branch      Branch           @relation(fields: [branchId], references: [id])
  createdAt   DateTime         @default(now())

  @@index([productId])
  @@index([branchId])
}

// One row per physical unit for IMEI/serial-tracked products
model ImeiRecord {
  id            String     @id @default(uuid())
  imei          String     @unique
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  status        ImeiStatus @default(IN_STOCK)
  purchaseItemId String?
  purchaseItem  PurchaseItem? @relation(fields: [purchaseItemId], references: [id])
  saleItemId    String?    @unique
  saleItem      SaleItem?  @relation(fields: [saleItemId], references: [id])
  branchId      String
  branch        Branch     @relation(fields: [branchId], references: [id])
  supplierId    String?
  supplier      Supplier?  @relation(fields: [supplierId], references: [id])
  receivedDate  DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  warrantyClaims WarrantyClaim[]
  sim            Sim?
  installations  InstallationRecord[]
  rmas           Rma[]

  @@index([status])
  @@index([productId])
  @@index([branchId])
}

// ------------------------------------------------------------------
// Sales
// ------------------------------------------------------------------

model Sale {
  id            String     @id @default(uuid())
  invoiceNumber String     @unique
  customerId    String
  customer      Customer   @relation(fields: [customerId], references: [id])
  userId        String
  user          User       @relation(fields: [userId], references: [id])
  branchId      String
  branch        Branch     @relation(fields: [branchId], references: [id])
  status        SaleStatus @default(DRAFT)
  gstType       GstType    @default(INTRA_STATE)
  placeOfSupply String?
  subtotal      Decimal    @db.Decimal(12, 2)
  taxTotal      Decimal    @db.Decimal(12, 2)
  cgstTotal     Decimal    @default(0) @db.Decimal(12, 2)
  sgstTotal     Decimal    @default(0) @db.Decimal(12, 2)
  igstTotal     Decimal    @default(0) @db.Decimal(12, 2)
  discountTotal Decimal    @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal    @db.Decimal(12, 2)
  amountPaid    Decimal    @default(0) @db.Decimal(12, 2)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  items    SaleItem[]
  returns  Return[]
  payments Payment[]

  @@index([customerId])
  @@index([invoiceNumber])
  @@index([branchId])
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  taxPercent Decimal  @default(0) @db.Decimal(5, 2)
  hsnCode    String?
  cgstAmount Decimal  @default(0) @db.Decimal(12, 2)
  sgstAmount Decimal  @default(0) @db.Decimal(12, 2)
  igstAmount Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)

  imei           ImeiRecord?
  warrantyClaims WarrantyClaim[]
  returnItems    ReturnItem[]

  @@index([saleId])
  @@index([productId])
}

// ------------------------------------------------------------------
// Purchases
// ------------------------------------------------------------------

model Purchase {
  id             String         @id @default(uuid())
  purchaseNumber String         @unique
  supplierId     String
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  branchId       String
  branch         Branch         @relation(fields: [branchId], references: [id])
  status         PurchaseStatus @default(DRAFT)
  invoiceNumber  String?
  purchaseDate   DateTime       @default(now())
  subtotal       Decimal        @db.Decimal(12, 2)
  taxTotal       Decimal        @db.Decimal(12, 2)
  grandTotal     Decimal        @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items    PurchaseItem[]
  payments Payment[]

  @@index([supplierId])
  @@index([branchId])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitCost   Decimal  @db.Decimal(12, 2)
  taxPercent Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)

  imeiRecords ImeiRecord[]

  @@index([purchaseId])
  @@index([productId])
}

// ------------------------------------------------------------------
// Returns / Refunds / Replacements
// ------------------------------------------------------------------

model Return {
  id         String       @id @default(uuid())
  saleId     String
  sale       Sale         @relation(fields: [saleId], references: [id])
  customerId String
  customer   Customer     @relation(fields: [customerId], references: [id])
  type       ReturnType
  status     ReturnStatus @default(PENDING)
  reason     String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  items ReturnItem[]

  @@index([saleId])
}

model ReturnItem {
  id         String   @id @default(uuid())
  returnId   String
  returnRec  Return   @relation(fields: [returnId], references: [id])
  saleItemId String
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id])
  quantity   Int
  refundAmt  Decimal  @default(0) @db.Decimal(12, 2)

  @@index([returnId])
}

// ------------------------------------------------------------------
// Warranty
// ------------------------------------------------------------------

model WarrantyClaim {
  id           String         @id @default(uuid())
  imeiRecordId String?
  imeiRecord   ImeiRecord?    @relation(fields: [imeiRecordId], references: [id])
  saleItemId   String?
  saleItem     SaleItem?      @relation(fields: [saleItemId], references: [id])
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id])
  status       WarrantyStatus @default(ACTIVE)
  claimDate    DateTime       @default(now())
  resolvedDate DateTime?
  description  String?
  resolution   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([customerId])
  @@index([imeiRecordId])
}

// ------------------------------------------------------------------
// Payments
// ------------------------------------------------------------------

model Payment {
  id          String           @id @default(uuid())
  direction   PaymentDirection
  method      PaymentMethod
  amount      Decimal          @db.Decimal(12, 2)
  saleId      String?
  sale        Sale?            @relation(fields: [saleId], references: [id])
  purchaseId  String?
  purchase    Purchase?        @relation(fields: [purchaseId], references: [id])
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id])
  reference   String?
  createdAt   DateTime         @default(now())

  @@index([saleId])
  @@index([purchaseId])
}

// ------------------------------------------------------------------
// Notifications, Audit, Files, Settings
// ------------------------------------------------------------------

model Notification {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  type      NotificationType  @default(INFO)
  title     String
  message   String
  isRead    Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

model File {
  id         String   @id @default(uuid())
  filename   String
  path       String
  mimeType   String
  size       Int
  entityType String?
  entityId   String?
  uploadedBy String?
  uploader   User?    @relation(fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value Json
}

// ------------------------------------------------------------------
// GPS Business: SIM Management, Vehicles, Installations, RMA
// ------------------------------------------------------------------

model Sim {
  id           String           @id @default(uuid())
  iccid        String           @unique
  msisdn       String?
  carrier      SimCarrier       @default(OTHER)
  billingCycle SimBillingCycle?
  status       SimStatus        @default(AVAILABLE)
  customerId   String?
  customer     Customer?        @relation(fields: [customerId], references: [id])
  imeiRecordId String?    @unique
  imeiRecord   ImeiRecord? @relation(fields: [imeiRecordId], references: [id])
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id])
  purchaseDate DateTime   @default(now())
  saleDate     DateTime?
  expiryDate   DateTime?
  activatedAt  DateTime?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  installations InstallationRecord[]
  renewals      SimRenewal[]

  @@index([status])
  @@index([customerId])
  @@index([branchId])
  @@index([carrier])
  @@index([expiryDate])
}

model SimRenewal {
  id                 String          @id @default(uuid())
  simId              String
  sim                Sim             @relation(fields: [simId], references: [id])
  billingCycle       SimBillingCycle
  previousExpiryDate DateTime?
  newExpiryDate      DateTime
  renewedById        String?
  renewedBy          User?           @relation(fields: [renewedById], references: [id])
  createdAt          DateTime        @default(now())

  @@index([simId])
}

model Vehicle {
  id                 String   @id @default(uuid())
  registrationNumber String   @unique
  make               String?
  model              String?
  year               Int?
  ownerCustomerId    String
  ownerCustomer      Customer @relation(fields: [ownerCustomerId], references: [id])
  branchId           String
  branch             Branch   @relation(fields: [branchId], references: [id])
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  installations InstallationRecord[]

  @@index([ownerCustomerId])
  @@index([branchId])
}

model InstallationRecord {
  id             String              @id @default(uuid())
  vehicleId      String
  vehicle        Vehicle             @relation(fields: [vehicleId], references: [id])
  imeiRecordId   String
  imeiRecord     ImeiRecord          @relation(fields: [imeiRecordId], references: [id])
  simId          String?
  sim            Sim?                @relation(fields: [simId], references: [id])
  installedBy    String
  installer      User                @relation(fields: [installedBy], references: [id])
  branchId       String
  branch         Branch              @relation(fields: [branchId], references: [id])
  status         InstallationStatus  @default(SCHEDULED)
  scheduledDate  DateTime?
  installedDate  DateTime?
  removedDate    DateTime?
  location       String?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([vehicleId])
  @@index([imeiRecordId])
  @@index([status])
  @@index([branchId])
}

model Rma {
  id                    String    @id @default(uuid())
  imeiRecordId          String
  imeiRecord            ImeiRecord @relation(fields: [imeiRecordId], references: [id])
  supplierId            String
  supplier              Supplier  @relation(fields: [supplierId], references: [id])
  branchId              String
  branch                Branch    @relation(fields: [branchId], references: [id])
  status                RmaStatus @default(REQUESTED)
  reason                String
  shippedDate           DateTime?
  resolvedDate          DateTime?
  replacementImeiRecordId String? @unique
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([imeiRecordId])
  @@index([supplierId])
  @@index([status])
  @@index([branchId])
}
