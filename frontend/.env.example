# Leave unset for local dev — requests fall back to the relative path proxied
# by vite.config.ts to http://127.0.0.1:4000.
#
# Set in production (e.g. Vercel project settings) to the deployed backend's
# base URL, with no trailing slash:
# VITE_API_URL=https://alphatech-api.onrender.com
VITE_API_URL=
